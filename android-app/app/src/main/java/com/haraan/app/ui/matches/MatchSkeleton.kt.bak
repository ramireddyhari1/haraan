package com.example.thanna.ui.matches

import androidx.compose.animation.core.*
import androidx.compose.foundation.background
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.shape.CircleShape
import androidx.compose.foundation.shape.RoundedCornerShape
import androidx.compose.material3.Card
import androidx.compose.material3.CardDefaults
import androidx.compose.runtime.Composable
import androidx.compose.runtime.getValue
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.composed
import androidx.compose.ui.draw.clip
import androidx.compose.ui.geometry.Offset
import androidx.compose.ui.graphics.Brush
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.unit.Dp
import androidx.compose.ui.unit.dp
import com.example.thanna.ui.theme.premiumCardShadow

// ─────────────────────────────────────────────
//  SKELETON SHIMMER LOADING
//  Mirrors the real Match Details layout: full-bleed dark broadcast hero, sticky
//  tabs, and light content cards below — so the screen feels present while loading.
// ─────────────────────────────────────────────

/** Animated shimmer fill for light surfaces. Apply after .clip(shape). */
fun Modifier.shimmer(): Modifier = composed {
    val transition = rememberInfiniteTransition(label = "shimmer")
    val translate by transition.animateFloat(
        initialValue = -2f,
        targetValue = 2f,
        animationSpec = infiniteRepeatable(
            animation = tween(1200, easing = LinearEasing),
            repeatMode = RepeatMode.Restart
        ),
        label = "shimmerTranslate"
    )
    val base = CrexColors.Border
    val highlight = CrexColors.Surface
    background(
        brush = Brush.linearGradient(
            colors = listOf(base, highlight, base),
            start = Offset(translate * 300f, 0f),
            end = Offset(translate * 300f + 300f, 300f)
        )
    )
}

/** Dark hero shimmer — white/slate band over midnight base. */
private fun Modifier.darkShimmer(): Modifier = composed {
    val transition = rememberInfiniteTransition(label = "darkShimmer")
    val translate by transition.animateFloat(
        initialValue = -2f,
        targetValue = 2f,
        animationSpec = infiniteRepeatable(
            animation = tween(1400, easing = LinearEasing),
            repeatMode = RepeatMode.Restart
        ),
        label = "darkShimmerTranslate"
    )
    val base = Color.White.copy(alpha = 0.06f)
    val highlight = Color.White.copy(alpha = 0.14f)
    background(
        brush = Brush.linearGradient(
            colors = listOf(base, highlight, base),
            start = Offset(translate * 280f, 0f),
            end = Offset(translate * 280f + 280f, 280f)
        )
    )
}

@Composable
private fun ShimmerBlock(
    width: Dp,
    height: Dp,
    radius: Dp = 6.dp,
    modifier: Modifier = Modifier,
    dark: Boolean = false,
) {
    Box(
        modifier = modifier
            .then(if (width == Dp.Unspecified) Modifier.fillMaxWidth() else Modifier.width(width))
            .height(height)
            .clip(RoundedCornerShape(radius))
            .then(if (dark) Modifier.darkShimmer() else Modifier.shimmer())
    )
}

@Composable
fun MatchDetailsSkeleton(modifier: Modifier = Modifier) {
    val midnight = Color(0xFF070B18)
    Column(
        modifier = modifier
            .fillMaxSize()
            .background(CrexColors.Background)
    ) {
        // Full-bleed broadcast hero skeleton (matches BroadcastHeader shape)
        Box(
            modifier = Modifier
                .fillMaxWidth()
                .height(290.dp)
                .background(
                    Brush.verticalGradient(
                        listOf(Color(0xFF0D1B3E), midnight)
                    )
                )
                .statusBarsPadding()
                .padding(top = 52.dp, start = 18.dp, end = 18.dp, bottom = 14.dp)
        ) {
            Column(verticalArrangement = Arrangement.spacedBy(14.dp)) {
                Row(
                    Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    ShimmerBlock(width = 52.dp, height = 18.dp, radius = 6.dp, dark = true)
                    ShimmerBlock(width = 96.dp, height = 12.dp, radius = 6.dp, dark = true)
                }
                Row(
                    Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.SpaceBetween,
                    verticalAlignment = Alignment.Bottom
                ) {
                    Row(
                        verticalAlignment = Alignment.CenterVertically,
                        horizontalArrangement = Arrangement.spacedBy(10.dp)
                    ) {
                        Box(Modifier.size(44.dp).clip(CircleShape).darkShimmer())
                        Column(verticalArrangement = Arrangement.spacedBy(6.dp)) {
                            ShimmerBlock(width = 56.dp, height = 16.dp, radius = 6.dp, dark = true)
                            ShimmerBlock(width = 44.dp, height = 10.dp, radius = 4.dp, dark = true)
                        }
                    }
                    ShimmerBlock(width = 120.dp, height = 40.dp, radius = 10.dp, dark = true)
                }
                ShimmerBlock(width = Dp.Unspecified, height = 40.dp, radius = 12.dp, dark = true)
                ShimmerBlock(width = 140.dp, height = 12.dp, radius = 6.dp, dark = true)
                ShimmerBlock(width = Dp.Unspecified, height = 7.dp, radius = 50.dp, dark = true)
            }
        }

        // Sticky tab row skeleton
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .background(CrexColors.Surface.copy(alpha = 0.9f))
                .padding(horizontal = 16.dp, vertical = 12.dp),
            horizontalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            repeat(4) { ShimmerBlock(width = 56.dp, height = 14.dp) }
        }

        // Content cards below the fold
        Column(
            modifier = Modifier
                .fillMaxWidth()
                .padding(horizontal = 16.dp, vertical = 16.dp),
            verticalArrangement = Arrangement.spacedBy(16.dp)
        ) {
            repeat(2) {
                Card(
                    shape = RoundedCornerShape(16.dp),
                    colors = CardDefaults.cardColors(containerColor = CrexColors.Card),
                    elevation = CardDefaults.cardElevation(defaultElevation = 0.dp),
                    modifier = Modifier.fillMaxWidth().premiumCardShadow(radius = 16.dp)
                ) {
                    Column(Modifier.fillMaxWidth().padding(16.dp), verticalArrangement = Arrangement.spacedBy(12.dp)) {
                        ShimmerBlock(width = 140.dp, height = 14.dp)
                        ShimmerBlock(width = Dp.Unspecified, height = 12.dp)
                        ShimmerBlock(width = Dp.Unspecified, height = 12.dp)
                        ShimmerBlock(width = 200.dp, height = 12.dp)
                    }
                }
            }
        }
    }
}

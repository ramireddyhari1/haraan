    VenueDetail("s1", "Greenfield Arena", "Andheri East", "4.7", current.category, current.price + 100,
        categoryImage(current.category), "Premium turf · 2 grounds", "2.6 km"),
    VenueDetail("s2", "Smash Court", "Vile Parle", "4.5", current.category, (current.price - 100).coerceAtLeast(200),
        IMG_BADMINTON, "Indoor wooden courts", "3.4 km"),
    VenueDetail("s3", "Apex Sports Hub", "Goregaon", "4.8", current.category, current.price + 50,
        IMG_FOOTBALL, "Floodlit · cafeteria", "4.1 km"),
).filter { it.id != current.id }


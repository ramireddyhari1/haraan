// Rotating "X just booked" proof — slides in, holds, slides out, then advances to
// the next booking. Reinforces that slots are actively going.
@Composable
private fun RecentlyBookedBanner() {
    val bookings = remember {
        listOf(
            "Rahul booked the 6 PM slot" to "12 min ago",
            "Sneha booked the 8 PM slot" to "34 min ago",
            "Vikram booked the 5 PM slot" to "1 hr ago"
        )
    }
    var idx by remember { mutableStateOf(0) }
    var shown by remember { mutableStateOf(false) }
    LaunchedEffect(Unit) {
        kotlinx.coroutines.delay(900)
        while (true) {
            shown = true
            kotlinx.coroutines.delay(3400)
            shown = false
            kotlinx.coroutines.delay(450)
            idx = (idx + 1) % bookings.size
        }
    }
    AnimatedVisibility(
        visible = shown,
        enter = slideInVertically { it / 2 } + fadeIn(),
        exit = slideOutVertically { it / 2 } + fadeOut()
    ) {
        val (who, ago) = bookings[idx]
        Row(
            verticalAlignment = Alignment.CenterVertically,
            modifier = Modifier
                .fillMaxWidth()
                .clip(RoundedCornerShape(12.dp))
                .background(HaraanColors.GameHubGreen.copy(alpha = 0.08f))
                .padding(horizontal = 12.dp, vertical = 9.dp)
        ) {
            Box(
                modifier = Modifier.size(22.dp).clip(CircleShape).background(HaraanColors.GameHubGreen.copy(alpha = 0.18f)),
                contentAlignment = Alignment.Center
            ) { Icon(Icons.Default.Check, null, tint = HaraanColors.GameHubGreen, modifier = Modifier.size(13.dp)) }
            Spacer(Modifier.width(9.dp))
            Text(who, color = HaraanColors.TextSecondary, fontSize = 12.sp, fontWeight = FontWeight.SemiBold, modifier = Modifier.weight(1f))
            Text(ago, color = HaraanColors.TextMuted, fontSize = 11.sp)
        }
    }
}

private data class VenueReview(val name: String, val rating: Int, val text: String, val initial: String, val ago: String, val avatar: String)

private fun venueReviews(): List<VenueReview> = listOf(
    VenueReview("Arjun M.", 5, "Great surface and the floodlights are genuinely bright. Booking took 10 seconds.", "A", "2 weeks ago", "https://i.pravatar.cc/100?img=12"),
    VenueReview("Priya S.", 4, "Clean washrooms, easy parking. Got a little crowded by 8 PM but worth it.", "P", "1 month ago", "https://i.pravatar.cc/100?img=45"),
)

// Opens the device maps app with the venue as the destination query.
private fun openDirections(context: android.content.Context, query: String) {
    try {
        val uri = android.net.Uri.parse("geo:0,0?q=" + android.net.Uri.encode(query))
        context.startActivity(
            android.content.Intent(android.content.Intent.ACTION_VIEW, uri)
                .addFlags(android.content.Intent.FLAG_ACTIVITY_NEW_TASK)
        )
    } catch (_: Exception) {
        Toast.makeText(context, "No maps app found.", Toast.LENGTH_SHORT).show()
    }
}


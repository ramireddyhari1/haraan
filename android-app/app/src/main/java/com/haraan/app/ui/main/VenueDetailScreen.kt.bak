@Composable
private fun SlotChip(
    time: String,
    available: Boolean,
    selected: Boolean,
    fillingFast: Boolean = false,
    onClick: () -> Unit,
    modifier: Modifier = Modifier
) {
    val interaction = remember { MutableInteractionSource() }
    val pressed by interaction.collectIsPressedAsState()
    val scale by animateFloatAsState(if (pressed && available) 0.93f else 1f, spring(dampingRatio = 0.72f, stiffness = 380f), label = "slot")
    // Reward the choice: a spring pop the moment this slot becomes the selected one.
    val selectPop = remember { Animatable(1f) }
    LaunchedEffect(selected) {
        if (selected) {
            selectPop.snapTo(1.16f)
            selectPop.animateTo(1f, spring(dampingRatio = 0.42f, stiffness = 340f))
        }
    }
    val bg by animateColorAsState(
        when {
            !available -> HaraanColors.Background
            selected -> HaraanColors.GameHubGreen
            else -> HaraanColors.Surface
        }, tween(180), label = "slotBg"
    )
    val fg = when {
        !available -> HaraanColors.TextMuted
        selected -> Color.White
        else -> HaraanColors.TextPrimary
    }
    val showUrgent = fillingFast && available && !selected
    Box(
        modifier = modifier
            .graphicsLayer { scaleX = scale * selectPop.value; scaleY = scale * selectPop.value }
            .then(
                if (selected) Modifier.shadow(
                    elevation = 10.dp,
                    shape = RoundedCornerShape(10.dp),
                    clip = false,
                    ambientColor = HaraanColors.GameHubGreen.copy(alpha = 0.55f),
                    spotColor = HaraanColors.GameHubGreen.copy(alpha = 0.65f)
                ) else Modifier
            )
            .clip(RoundedCornerShape(10.dp))
            .background(bg)
            .border(
                1.dp,
                when {
                    selected -> Color.Transparent
                    showUrgent -> Color(0xFFEA580C).copy(alpha = 0.45f)
                    else -> HaraanColors.BorderLight
                },
                RoundedCornerShape(10.dp)
            )
            .clickable(interactionSource = interaction, indication = null, enabled = available) { onClick() }
            .padding(vertical = 8.dp),
        contentAlignment = Alignment.Center
    ) {
        Column(horizontalAlignment = Alignment.CenterHorizontally) {
            Text(
                text = time,
                color = fg,
                fontSize = 12.sp,
                fontWeight = if (selected) FontWeight.Bold else FontWeight.SemiBold,
                style = TextStyle(
                    fontFeatureSettings = "tnum",
                    textDecoration = if (!available) androidx.compose.ui.text.style.TextDecoration.LineThrough else null
                )
            )
            AnimatedVisibility(
                visible = selected,
                enter = scaleIn(spring(dampingRatio = 0.45f, stiffness = 340f)) + fadeIn(),
                exit = scaleOut() + fadeOut()
            ) {
                Row(verticalAlignment = Alignment.CenterVertically, modifier = Modifier.padding(top = 2.dp)) {
                    Icon(Icons.Default.Check, null, tint = Color.White, modifier = Modifier.size(10.dp))
                    Spacer(Modifier.width(3.dp))
                    Text("Selected", color = Color.White, fontSize = 9.sp, fontWeight = FontWeight.Bold)
                }
            }
            if (showUrgent) {
                Spacer(Modifier.height(2.dp))
                Text("Filling fast", color = Color(0xFFEA580C), fontSize = 9.sp, fontWeight = FontWeight.Bold)
            } else if (!available) {
                Spacer(Modifier.height(2.dp))
                Text("Booked", color = HaraanColors.TextMuted, fontSize = 9.sp, fontWeight = FontWeight.Medium)
            }
        }
    }
}

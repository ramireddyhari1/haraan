private data class VenueSlot(val time: String, val available: Boolean, val fillingFast: Boolean = false)

private fun venueSlots(): List<VenueSlot> = listOf(
    VenueSlot("06:00 AM", true), VenueSlot("07:00 AM", true), VenueSlot("08:00 AM", false),
    VenueSlot("05:00 PM", true, fillingFast = true), VenueSlot("06:00 PM", true), VenueSlot("07:00 PM", false),
    VenueSlot("08:00 PM", true, fillingFast = true), VenueSlot("09:00 PM", true), VenueSlot("10:00 PM", true),
)

@Composable
private fun SlotGroup(title: String, slots: List<VenueSlot>, selected: String?, onSelect: (String) -> Unit) {
    if (slots.isEmpty()) return
    Text(
        title,
        color = HaraanColors.TextSecondary,
        fontSize = 14.sp,
        fontWeight = FontWeight.SemiBold,
        letterSpacing = (-0.1).sp
    )
    Spacer(Modifier.height(HaraanSpacing.Small))
    slots.chunked(3).forEach { row ->
        Row(
            modifier = Modifier.fillMaxWidth().padding(bottom = 8.dp),
            horizontalArrangement = Arrangement.spacedBy(8.dp)
        ) {
            row.forEach { slot ->
                SlotChip(
                    time = slot.time,
                    available = slot.available,
                    selected = selected == slot.time,
                    fillingFast = slot.fillingFast,
                    onClick = { onSelect(slot.time) },
                    modifier = Modifier.weight(1f)
                )
            }
            repeat(3 - row.size) { Spacer(Modifier.weight(1f)) }
        }
    }
    Spacer(Modifier.height(4.dp))
}

